algoritmo "semnome"
var
   V1, V2, Soma: Inteiro

Procedimento Somador (T: Inteiro)
Inicio
      T <- V1 + V2
      Escreva ("Soma = ", T)
FimProcedimento



inicio
      Escreva ("Digite um valor: ")
      Leia(V1)
      
      Escreva ("Digite outro valor: ")
      Leia(V2)
      
      Somador(Soma)
fimalgoritmo