algoritmo "semnome"
var
   Vet: Vetor [0..7] de Caractere
   N: Inteiro
inicio
      Para N <- 0 ate 7 faca
      Vet [N] <- "999"
      Escreva (" |", Vet[N], "| ")
      FimPara
      
      Escreval (" ")
      Para N <- 0 ate 7 faca
      Escreva ("  ", N, "   ")
      FimPara
fimalgoritmo