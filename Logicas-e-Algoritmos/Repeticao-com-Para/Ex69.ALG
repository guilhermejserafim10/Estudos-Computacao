algoritmo "Progressao-Aritmetica"
var
   Pter, Razao, N, ProximoT: Inteiro
inicio
      Escreva ("Digite o primeiro termo: ")
      Leia(Pter)
      Escreva ("Digite a razao da PA: ")
      Leia (Razao)
      
      Escreva (Pter)
      Para N de 1 ate 10 passo 1 faca
      Pter <- Pter + Razao
       Escreva (Pter)
      FimPara
fimalgoritmo